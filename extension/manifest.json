{
  "manifest_version": 3,
  "name": "AI Interview Detector",
  "version": "1.0",
  "description": "Detect AI-generated answers",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}